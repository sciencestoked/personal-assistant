# LLM Configuration
# Choose provider: ollama, openai, anthropic, groq
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Groq (optional, free tier available)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Google Calendar
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json
GOOGLE_TOKEN_PATH=config/google_token.json

# Notion
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Email Configuration
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Database
DATABASE_URL=sqlite:///data/assistant.db

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Scheduling
DAILY_BRIEFING_TIME=08:00
EVENING_SUMMARY_TIME=20:00

# Notifications
NOTIFICATION_EMAIL=your_email@gmail.com
ENABLE_TERMINAL_NOTIFICATIONS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/assistant.log
